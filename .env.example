# Copy to .env and fill in. Never commit the real .env.

# Flask session signing secret (random, long). Rotating it logs everyone out.
SECRET_KEY=change-me-to-a-long-random-string

# Session cookie name shared across the ap-pie SSO family.
SESSION_COOKIE_NAME=apie_session
# Leading dot shares the cookie across all *.ap-pie.com subdomains.
SESSION_COOKIE_DOMAIN=.ap-pie.com

# Discord OAuth2 application credentials (Discord Developer Portal).
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
# Must exactly match a redirect URI registered on the Discord app.
DISCORD_REDIRECT_URI=https://digipelago.ap-pie.com/api/auth/callback

# Fernet key for encrypting saved slot passwords (urlsafe base64, 32 bytes).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DIGIPELAGO_CRED_KEY=change-me-fernet-key

# Postgres container credentials (used by the db service + DATABASE_URL).
POSTGRES_DB=digipelago
POSTGRES_USER=digipelago
POSTGRES_PASSWORD=change-me-db-password

# psycopg connection string. Host 'db' is the compose service name.
DATABASE_URL=postgresql://digipelago:change-me-db-password@db:5432/digipelago
